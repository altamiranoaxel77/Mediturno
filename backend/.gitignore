# =============================================================================
# .gitignore — Archivos y carpetas excluidos del repositorio
# =============================================================================

# ── Entorno virtual de Python ─────────────────────────────────────────────────
# Nunca subir el venv — cada desarrollador crea el suyo con:
# python -m venv venv && pip install -r requirements.txt
venv/
env/
.venv/
.env/

# ── Variables de entorno ──────────────────────────────────────────────────────
# Contiene contraseñas y claves secretas — NUNCA subir al repo
.env

# ── Python: archivos compilados y caché ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── Distribución / empaquetado ────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDEs y editores ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store       # macOS
Thumbs.db       # Windows

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Frontend (Node.js / Vue) ──────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local